# Production Environment Variables Template
# Copy this file to .env.production before building for production
#
# IMPORTANT: Update the URL to your actual deployed backend!
# This value gets embedded into the JavaScript bundle during build.
#
# For Vercel/Netlify deployments: Set VITE_API_URL in their dashboard
# instead of using this file (they inject env vars at build time).

VITE_API_URL=https://your-backend-name.onrender.com/api
