# Backend Environment Variables
# Copy this file to .env and fill in the values

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS - Frontend URL (update for production)
FRONTEND_URL=http://localhost:5173

# NASA API Key
# Get your free key at: https://api.nasa.gov
# DEMO_KEY works for limited testing
NASA_API_KEY=DEMO_KEY

# Optional: Rate limiting whitelist (comma-separated IPs)
# RATE_LIMIT_WHITELIST=127.0.0.1,::1

# Optional: Custom User-Agent for Nominatim requests
# NOMINATIM_USER_AGENT=CosmicTimeline/1.0
